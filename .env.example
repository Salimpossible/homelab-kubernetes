# VPN Provider Config (Gluetun)
# Supported: protonvpn, surfshark, expressvpn, nordvpn, windscribe, etc.
VPNSP=nordvpn

# Use VPN service credentials (not account login credentials if provider has separate service creds)
OPENVPN_USER=REPLACE_WITH_VPN_USERNAME
OPENVPN_PASSWORD=REPLACE_WITH_VPN_PASSWORD

# Optional for WireGuard providers
WIREGUARD_PRIVATE_KEY=REPLACE_WITH_WIREGUARD_PRIVATE_KEY

# System Config
PUID=1000
PGID=1000
TZ=Europe/Paris

# Plex Setup Token (get from https://www.plex.tv/claim)
PLEX_CLAIM=REPLACE_WITH_PLEX_CLAIM
